# Dynamic Workers orchestrator URL (local dev or production)
ORCHESTRATOR_URL=http://localhost:8787

# Coins to track (CoinGecko IDs, comma-separated)
TRACKED_COINS=bitcoin,ethereum,solana,dogecoin,cardano,polkadot,chainlink,avalanche-2

# Price poll interval in seconds
PRICE_INTERVAL=10.0

# GitHub context for orchestrator tasks (optional — used when submitting analysis)
GITHUB_OWNER=myorg
GITHUB_REPO=crypto-terminal
