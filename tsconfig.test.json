{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types", "jest", "node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "noEmit": true,
    // Tests re-import source via `./foo.js` style (ESM NodeNext semantics in
    // the source tree). ts-jest with the moduleNameMapper strips the .js.
    "verbatimModuleSyntax": false
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}
